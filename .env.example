# =============================================================================
# RAG Donanım ve OCR Yapılandırması
# =============================================================================

# Hangi OCR motorunun kullanılacağı
# Seçenekler: "easyocr", "tesseract", "mac" (sadece macOS)
OCR_ENGINE=easyocr

# EasyOCR için GPU kullanılsın mı?
# Seçenekler: 
#   - auto  (GPU varsa otomatik kullanır, yoksa CPU'ya döner)
#   - true  (GPU kullanımını zorlar)
#   - false (CPU kullanımını zorlar)
DOCLING_USE_GPU=auto

# Late Chunking özelliğini aktif et (1 veya 0)
USE_LOCAL_LATE_CHUNKING=0
